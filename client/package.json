{
  "name": "mini-shop-client",
  "version": "1.0.0",
  "private": true,
  "description": "京东风格小程序商城 - Taro 3 + React + TypeScript",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "taro build --type h5 --watch",
    "build:h5": "taro build --type h5"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/cli": "3.6.25",
    "@tarojs/components": "3.6.25",
    "@tarojs/helper": "3.6.25",
    "@tarojs/plugin-framework-react": "3.6.25",
    "@tarojs/plugin-platform-h5": "3.6.25",
    "@tarojs/plugin-platform-weapp": "3.6.25",
    "@tarojs/react": "3.6.25",
    "@tarojs/runtime": "3.6.25",
    "@tarojs/shared": "3.6.25",
    "@tarojs/taro": "3.6.25",
    "@tarojs/taro-h5": "3.6.25",
    "@tarojs/webpack5-runner": "3.6.25",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/plugin-transform-class-properties": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@types/react": "^18.0.0",
    "@types/webpack-env": "^1.13.6",
    "babel-preset-taro": "^4.1.11",
    "sass": "^1.62.0",
    "typescript": "^5.0.0"
  }
}
